# Environment Variables for Next.js App

# PartyKit Server URL (REQUIRED for production)
# Get this from your PartyKit deployment output after running: npx partykit deploy
# Format: your-project.your-username.partykit.dev (without https://)
# Example: lesury.clickout.partykit.dev
# 
# For local development, you can use: localhost:1999 (default)
NEXT_PUBLIC_PARTYKIT_HOST=

# Google Apps Script Web App URL for lead capture
# See: https://script.google.com — deploy as Web App, set access to "Anyone"
GOOGLE_APPS_SCRIPT_URL=
